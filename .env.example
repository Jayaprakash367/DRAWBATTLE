# DrawBattle Environment Configuration

# Server Port (ignored in Vercel)
PORT=5000

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Environment
NODE_ENV=development

# DATABASE CONFIG
# For local development: Leave DATABASE_URL empty (uses SQLite)
# For Vercel/Production: Set to PostgreSQL connection string
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Optional: AI/ML Models (for solo prediction mode)
# TENSORFLOW_JS_BACKEND=cpu
